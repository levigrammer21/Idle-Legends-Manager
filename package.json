    "deploy:all": "npm run build && firebase deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "firebase": "latest",
    "lucide-react": "latest"
  },
  "devDependencies": {}
}
